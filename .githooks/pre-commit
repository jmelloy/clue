#!/usr/bin/env bash
set -euo pipefail

# Keep generated thumbnail assets in sync before commit.
./scripts/resize_thumbnails.sh

if [ -n "$(git status --porcelain frontend/public/images)" ]; then
  echo ""
  echo "Thumbnail files changed after resize."
  echo "Stage the updated files, then commit again:"
  echo "  git add frontend/public/images"
  echo "  git commit -m \"chore: regenerate image thumbnails\""
  exit 1
fi
